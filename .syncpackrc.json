{
	"$schema": "https://unpkg.com/syncpack@latest/schema.json",
	"sortAz": ["dependencies", "devDependencies", "peerDependencies", "resolutions", "overrides"],
	"sortFirst": [
		"name",
		"version",
		"private",
		"description",
		"license",
		"type",
		"main",
		"types",
		"exports",
		"scripts",
		"dependencies",
		"devDependencies",
		"peerDependencies"
	],
	"semverGroups": [
		{
			"label": "Internal workspace packages use workspace protocol",
			"dependencies": ["@njust-ai/*"],
			"dependencyTypes": ["prod", "dev"],
			"range": "workspace:*"
		},
		{
			"label": "TypeScript uses tilde range to stay within eslint compat",
			"dependencies": ["typescript"],
			"dependencyTypes": ["prod", "dev"],
			"range": "~"
		},
		{
			"label": "All dependencies use caret ranges",
			"range": "^",
			"dependencyTypes": ["prod", "dev"]
		}
	],
	"versionGroups": [
		{
			"label": "Workspace packages use workspace protocol",
			"dependencies": ["@njust-ai/*"],
			"dependencyTypes": ["prod", "dev"],
			"pinVersion": "workspace:^"
		},
		{
			"label": "Ensure consistent TypeScript version across packages",
			"dependencies": ["typescript"],
			"dependencyTypes": ["dev"]
		}
	]
}
