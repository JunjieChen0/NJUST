{
	"$schema": "https://turbo.build/schema.json",
	"extends": ["//"],
	"tasks": {
		"bundle": {
			"dependsOn": ["^build", "@njust-ai-cj/vscode-webview#build"],
			"outputs": ["dist/**"]
		},
		"vsix": {
			"dependsOn": ["bundle"],
			"inputs": ["dist/**", "bundled-skills/**", "bundled-cangjie-corpus/**", "package.json", ".vscodeignore"],
			"outputs": ["../bin/**"]
		},
		"watch:bundle": {
			"dependsOn": ["@njust-ai-cj/build#build", "@njust-ai-cj/types#build"],
			"cache": false
		}
	}
}
